{
  "name": "@aiproxyguard/sdk",
  "version": "1.0.0",
  "description": "Official TypeScript/JavaScript SDK for AIProxyGuard - LLM security proxy for prompt injection detection",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./middleware": {
      "types": "./dist/middleware/express.d.ts",
      "import": "./dist/middleware/express.mjs",
      "require": "./dist/middleware/express.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "aiproxyguard",
    "llm",
    "security",
    "prompt-injection",
    "ai",
    "sdk",
    "typescript"
  ],
  "author": "AINVIRION",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ainvirion/aiproxyguard-sdk"
  },
  "homepage": "https://aiproxyguard.com",
  "bugs": {
    "url": "https://github.com/ainvirion/aiproxyguard-sdk/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "express": "^4.0.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  }
}
