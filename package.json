{
  "name": "@ainvirion/aiproxyguard-npm-sdk",
  "version": "1.1.0",
  "description": "Official TypeScript/JavaScript SDK for AIProxyGuard - LLM security proxy for prompt injection detection",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./middleware": {
      "types": "./dist/middleware/express.d.ts",
      "import": "./dist/middleware/express.mjs",
      "require": "./dist/middleware/express.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "sync-version": "node -e \"const v=require('./package.json').version; require('fs').writeFileSync('src/version.ts', '/**\\n * SDK version - auto-synced from package.json\\n */\\nexport const version = \\x27'+v+'\\x27;\\n')\"",
    "prebuild": "npm run sync-version",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "aiproxyguard",
    "llm",
    "security",
    "prompt-injection",
    "ai",
    "sdk",
    "typescript"
  ],
  "author": {
    "name": "AINVIRION",
    "email": "support@ainvirion.com"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/AInvirion/aiproxyguard-npm-sdk"
  },
  "homepage": "https://ainvirion.github.io/aiproxyguard/",
  "bugs": {
    "url": "https://github.com/AInvirion/aiproxyguard-npm-sdk/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "express": "^4.0.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  }
}
